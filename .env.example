# Anthropic API Configuration
# Copy this file to .env and fill in your values.

# API key (required for live tests)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Base URL — change this for proxies or custom endpoints
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Model to test against
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# Request timeout in seconds
ANTHROPIC_TIMEOUT=30

# OpenAI API — judge model for Level 3 quality evals (DeepEval)
# Required only for test_eval_quality.py, skipped if not set
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4.1
